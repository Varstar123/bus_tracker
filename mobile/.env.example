# Copy to .env and fill in. Everything prefixed EXPO_PUBLIC_ is bundled into the
# app and is readable by anyone who downloads it -- never put a service_role key
# or any secret here. The anon key is safe: RLS is what protects the data.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Android only. Create at console.cloud.google.com -> Maps SDK for Android.
# Restrict it to your app's package name + SHA-1 before shipping.
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=

# From `eas init`. Needed for real push tokens.
EXPO_PUBLIC_EAS_PROJECT_ID=
