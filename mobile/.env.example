# Copy to .env and fill in.
#
# Everything prefixed EXPO_PUBLIC_ is INLINED INTO THE APP BUNDLE and is readable
# by anyone who downloads the APK. Never put a secret here.
#
# In particular: Supabase's *secret* key (sb_secret_...) must never appear in this
# file, or anywhere in the mobile app -- it bypasses every RLS policy. Edge
# Functions get it injected automatically by the platform; you never paste it.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Dashboard -> Settings -> API Keys. This is the CLIENT key, and it is safe to
# ship, because RLS is what protects the data -- not the key.
#   newer projects -> "Publishable key" -> sb_publishable_...
#   older projects -> "anon public"     -> eyJhbGciOi...
# Either name is accepted; set whichever your dashboard shows.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Android only. Google Cloud Console -> "Maps SDK for Android".
# Without this the map renders as a blank grey grid on Android. iOS uses Apple
# Maps and needs no key. Restrict it to your package name + SHA-1 before shipping.
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=

# From `npx eas init`. Needed for real push tokens.
EXPO_PUBLIC_EAS_PROJECT_ID=
